# CaptureShark environment variables
# Copy this file to .env and fill in real values. .env is gitignored.

# OpenAI — required for extraction (text, vision, voice transcription)
OPENAI_API_KEY=

# Google OAuth — required for Sheets connection (step 4 of the build)
# Walkthrough: docs/_workflow/04_google-oauth-setup.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session signing key — signs the HttpOnly `captureshark_session` cookie
# so the server can trust it on subsequent requests without keeping
# state in memory. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET_KEY=

# Fernet key — encrypts Google refresh tokens at rest in the SQLite db
# so a leaked DB file alone doesn't grant Google access. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Optional: override the default SQLite path for the auth/session/token
# store. Default is `backend/data/captureshark.db`.
# DATABASE_URL=sqlite+aiosqlite:///backend/data/captureshark.db

# Optional: pin the OAuth redirect base URL (e.g. https://captureshark.com)
# in production. In dev, leave blank — the server derives it from the
# incoming request, which is fine for localhost + tunnel testing.
# OAUTH_REDIRECT_BASE_URL=

# --- Sheets dev path (step 3) -----------------------------------------------
# Service-account-based write path for the demo / dev environment, used
# until OAuth lands in step 4. See docs/_workflow/03_sheets-dev-setup.md for
# the 5-minute Google Cloud Console setup.
GOOGLE_SERVICE_ACCOUNT_PATH=
DEV_TEST_SHEET_ID=
DEV_TEST_SHEET_TAB=Sheet1
# Optional override for the user-facing sheet name in the confirmation
# card. Leave blank to fetch the live title from Google.
DEV_TEST_SHEET_NAME=

# --- Feature flags ----------------------------------------------------------
# Live captions during voice capture (AssemblyAI streaming). ON by default
# as of 2026-05-15 — pipeline is code-complete, field-tested, in-app broker
# disclosure ships the first time voice is used. Set to `false` only as a
# kill switch (vendor incident, surprise cost spike) — the fallback path
# (MediaRecorder → Whisper batch) keeps voice capture working without
# redeploying any code.
LIVE_CAPTIONS_ENABLED=true

# AssemblyAI account API key — server-side ONLY. The browser never sees
# this; the backend mints short-lived temp tokens at /captures/live-token
# and the browser uses those to open the AssemblyAI WebSocket.
ASSEMBLYAI_API_KEY=

# Optional / carried-over from sister project; not required for v1
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# GOOGLE_TRANSLATE_API_KEY=
# SUPADATA_API_KEY=
